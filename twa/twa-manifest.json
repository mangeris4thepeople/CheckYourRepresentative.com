      "chosenIconUrl": "https://checkyourrepresentative.com/icons/icon-192.png"
    },
    {
      "name": "Know Your Judge",
      "short_name": "Judges",
      "url": "https://checkyourrepresentative.com/?tab=judges",
      "chosenIconUrl": "https://checkyourrepresentative.com/icons/icon-192.png"
    }
  ],
  "signingKey": {
    "path": "./android.keystore",
    "alias": "upload"
  },
  "webManifestUrl": "https://checkyourrepresentative.com/manifest.webmanifest"
