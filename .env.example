# Auto-set by Vercel when you create the Neon database (Storage -> Create Database):
DATABASE_URL=

# Copy this file to ".env" and fill in your real keys.
# NEVER commit your real .env file (it is git-ignored on purpose).

# From https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# From https://console.anthropic.com/ (Settings -> API Keys)
ANTHROPIC_API_KEY=

# Cloudflare Turnstile (https://dash.cloudflare.com -> Turnstile)
TURNSTILE_SECRET_KEY=

# A long random string you make up (used to sign vote tokens)
VOTE_IDENTITY_SALT=

# Optional: which Claude model writes the bill summaries (defaults to claude-sonnet-4-6)
SUMMARY_MODEL=

# From resend.com dashboard, API Keys
RESEND_API_KEY=

# Long random string, generate with openssl rand -hex 32
CRON_SECRET=

# From courtlistener.com profile, API page
COURTLISTENER_API_TOKEN=
