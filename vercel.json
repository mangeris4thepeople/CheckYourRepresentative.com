{
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/bill-detail", "destination": "/api/bills?op=bill-detail" },
    { "source": "/api/bill-summary", "destination": "/api/bills?op=bill-summary" },
    { "source": "/api/bills-list", "destination": "/api/bills?op=bills-list" },
    { "source": "/api/rollcall", "destination": "/api/bills?op=rollcall" },
    { "source": "/api/matrix", "destination": "/api/bills?op=matrix" },
    { "source": "/api/tally", "destination": "/api/bills?op=tally" },
    { "source": "/api/stats", "destination": "/api/bills?op=stats" },

    { "source": "/api/representative-detail", "destination": "/api/reps?op=representative-detail" },
    { "source": "/api/representatives-list", "destination": "/api/reps?op=representatives-list" },
    { "source": "/api/senator-detail", "destination": "/api/reps?op=senator-detail" },
    { "source": "/api/senators-list", "destination": "/api/reps?op=senators-list" },
    { "source": "/api/ngo-detail", "destination": "/api/reps?op=ngo-detail" },
    { "source": "/api/ngos", "destination": "/api/reps?op=ngos" },
    { "source": "/api/social-security-detail", "destination": "/api/reps?op=social-security-detail" },
    { "source": "/api/snap-national", "destination": "/api/reps?op=snap-national" },
    { "source": "/api/snap-state-detail", "destination": "/api/reps?op=snap-state-detail" },

    { "source": "/api/vote", "destination": "/api/votes?op=vote" },
    { "source": "/api/vote-status", "destination": "/api/votes?op=vote-status" },
    { "source": "/api/vote-queue-counts", "destination": "/api/votes?op=vote-queue-counts" },
    { "source": "/api/vote-queue-item", "destination": "/api/votes?op=vote-queue-item" },
    { "source": "/api/my-votes", "destination": "/api/votes?op=my-votes" },
    { "source": "/api/constituents", "destination": "/api/votes?op=constituents" },

    { "source": "/api/profile", "destination": "/api/account?op=profile" },
    { "source": "/api/geocode", "destination": "/api/account?op=geocode" },
    { "source": "/api/checkout", "destination": "/api/account?op=checkout" },
    { "source": "/api/digest", "destination": "/api/account?op=digest" },

    { "source": "/api/contact", "destination": "/api/messages?op=contact" },
    { "source": "/api/contact-us", "destination": "/api/messages?op=contact-us" },
    { "source": "/api/contact-track", "destination": "/api/messages?op=contact-track" },

    { "source": "/api/judges-list", "destination": "/api/judges?op=judges-list" },
    { "source": "/api/judge-detail", "destination": "/api/judges?op=judge-detail" },
    { "source": "/api/judge-courts", "destination": "/api/judges?op=judge-courts" },
    { "source": "/api/national-judges-list", "destination": "/api/judges?op=national-judges-list" },
    { "source": "/api/national-courts", "destination": "/api/judges?op=national-courts" }
  ],
  "crons": [
    {
      "path": "/api/cron?op=daily-report",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron?op=floor-alerts",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/cron?op=sync-bills",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron?op=verify-congress",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron?op=sync-reps",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron?op=sync-rep-finances",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron?op=sync-senators",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron?op=sync-senator-finances",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron?op=sync-national-judges",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron?op=sync-snap",
      "schedule": "0 11 * * 1"
    }
  ]
}
